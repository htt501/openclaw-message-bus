{
  "id": "openclaw-message-bus",
  "name": "A2A Message Bus",
  "version": "1.0.0",
  "description": "Agent-to-Agent async message bus with SQLite persistence",
  "entry": "index.js",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "agents": {
        "type": "array",
        "items": { "type": "string" },
        "description": "Valid agent IDs. Empty array = accept any agent (open mode)"
      },
      "notify": {
        "type": "object",
        "properties": {
          "enabled": { "type": "boolean", "default": true },
          "timeoutSeconds": { "type": "number", "default": 120 },
          "replyChannel": { "type": "string", "default": "" },
          "replyTo": { "type": "string", "default": "" }
        }
      }
    }
  }
}
